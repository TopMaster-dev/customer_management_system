# API base URL (no trailing slash). Same on Windows and Linux.
# Dev with proxy: /api (requests go to proxy target, e.g. http://localhost:8000/api)
# Production same host: /api
# Production different host: https://api.yourdomain.com
REACT_APP_API_URL=/api

# Dev server host (fixes "allowedHosts[0] should be a non-empty string")
HOST=localhost
PORT=3000
DANGEROUSLY_DISABLE_HOST_CHECK=true
